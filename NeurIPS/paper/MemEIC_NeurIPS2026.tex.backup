% ============================================================================
%  TITLE & AUTHORS
% ============================================================================
\title{When Not to Fuse: Diagnosing and Repairing\\
Cross-Modal Composition Failures\\
in Multimodal Knowledge Editing}

\author{%
  Dr.\ Prashanth Shukla \quad Dasari Veera Raghavulu\\
  NeurIPS 2026 Submission
